<scene version="2.1.0">

<!-- Regression replica of the legacy procedural relight scene that produced
     the smoke-test oracle envmap_rc.png:
       +scene.mesh=cloth +scene.mesh_scale=0.2 lighting=envmap
       camera.origin=[0,0,-1.5] camera.target=[0,0,0] fov 30, 512x512,
       path max_depth 4. -->

	<integrator type="path">
		<integer name="max_depth" value="4"/>
	</integrator>

	<sensor type="perspective">
		<float name="fov" value="30.0"/>
		<transform name="to_world">
			<lookat origin="0, 0, -1.5" target="0, 0, 0" up="0, 1, 0"/>
		</transform>
		<film type="hdrfilm">
			<integer name="width" value="512"/>
			<integer name="height" value="512"/>
		</film>
	</sensor>

	<!-- Draped cloth. to_world bakes the legacy auto-fit: bbox centered at the
	     origin, longest axis scaled to span 0.4 world units (mesh_scale 0.2). -->
	<shape type="obj" id="cloth">
		<string name="filename" value="../../assets/cloth.obj"/>
		<transform name="to_world">
			<matrix value="0.08560632192 0 0 -0.04750046229 0 0.08560632192 0 -0.05850014879 0 0 0.08560632192 -0.08256588494 0 0 0 1"/>
		</transform>
	</shape>

	<emitter type="envmap">
		<string name="filename" value="../../assets/envmap.exr"/>
		<float name="scale" value="1.0"/>
	</emitter>

</scene>
